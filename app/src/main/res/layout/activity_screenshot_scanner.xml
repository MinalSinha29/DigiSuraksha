<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:text="DigiSuraksha Scanner"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/screenshotPreview"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginBottom="15dp"
            android:background="#E0E0E0"
            android:padding="8dp"
            android:scaleType="fitCenter"/>

        <!-- SELECT BUTTON -->
        <Button
            android:id="@+id/selectScreenshot"
            android:text="Select Screenshot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- DETECTED TEXT SECTION -->
        <TextView
            android:text="Detected Text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/extractedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:text="Detected text will appear here"
            android:textSize="15sp"
            android:layout_marginBottom="15dp"/>

        <!-- RISK -->
        <TextView
            android:id="@+id/riskLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk Level: Unknown"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- FRAUD -->
        <TextView
            android:id="@+id/fraudWarning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <!-- EXPLANATION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:text="Analysis"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/explanationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- TIPS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:text="Safety Tips"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tipsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- SHARE BUTTON -->
        <Button
            android:id="@+id/shareSecure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Secure Share"/>

    </LinearLayout>

</ScrollView>